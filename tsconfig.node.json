{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler rules */
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "noEmit": true,

    /* Lint rules */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true
  },
  "include": ["vite.config.ts", "eslint.config.js"]
}
